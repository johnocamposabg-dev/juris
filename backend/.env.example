# Backend Environment Variables

# Ambiente Flask (development, production, testing)
FLASK_ENV=development

# URL de la base de datos
# Desarrollo: sqlite:///juris.db (archivo local)
# Producción: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///juris.db

# Clave secreta para tokens JWT (cambia esto en producción!)
# Genera una clave segura: openssl rand -hex 32
JWT_SECRET_KEY=change_me_with_a_secure_random_string

